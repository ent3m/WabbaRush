<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="{x:Type PathIcon}" TargetType="PathIcon" BasedOn="{StaticResource {x:Type PathIcon}}">
    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
    <Setter Property="Width" Value="22"/>
    <Setter Property="Height" Value="22"/>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type ComboBox}" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
    <!-- Conditional styles has higher priority than direct property setters in ControlTemplates.
    We use conditions ^:not(:disabled) and :disabled to override the glyph icon.
    Priorities are: direct setters in layout > conditional styles > direct setters in templates > plain styles. -->
    <Style Selector="^:not(:disabled) /template/ PathIcon#DropDownGlyph">
      <Setter Property="Data" Value="{StaticResource DownArrowIcon}" />
    </Style>
    <Style Selector="^:disabled /template/ PathIcon#DropDownGlyph">
      <Setter Property="Data" Value="{StaticResource DownArrowIcon}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>