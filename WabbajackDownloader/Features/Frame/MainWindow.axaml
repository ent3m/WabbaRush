<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:WabbajackDownloader.Features.Frame"
        x:Class="WabbajackDownloader.Features.Frame.MainWindow"
        x:DataType="local:MainWindowViewModel"
        Icon="{StaticResource AppIcon}"
        Title="WabbaRush"
        Height="720" Width="1280"
        WindowDecorations="Full"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur"
        Background="{DynamicResource WindowBackgroundBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <MergeResourceInclude Source="/Features/Frame/Shell.axaml"/>
        <MergeResourceInclude Source="/Features/Frame/ControlThemes.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <local:Shell />

</Window>
