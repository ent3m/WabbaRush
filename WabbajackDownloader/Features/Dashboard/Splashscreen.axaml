<Window xmlns="https://github.com/avaloniaui"
        xmlns:codeanalysis="using:System.Diagnostics.CodeAnalysis"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:WabbajackDownloader.Features.Dashboard"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="300"
        x:Class="WabbajackDownloader.Features.Dashboard.Splashscreen"
        x:DataType="local:SplashscreenViewModel"
        Width="280"
        Height="280"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Topmost="True"
        Background="Transparent"
        BorderBrush="Transparent"
        Title="WabbaRush">

  <StackPanel Orientation="Vertical">
    <Image Source="/Assets/wabbajack.png"
           Width="260"
           Height="260"/>
    <TextBlock Name="loadingText"
               Text="{Binding LoadingText}"
               FontWeight="Bold"
               TextAlignment="Center"/>
  </StackPanel>
  
</Window>
