<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WabbajackDownloader.App">

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Light" Accent="#9500FF"/>
        <ColorPaletteResources x:Key="Dark" Accent="#9547CC"/>
      </FluentTheme.Palettes>
    </FluentTheme>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <MergeResourceInclude Source="/Common/Themes/ColorPalette.axaml"/>
        <MergeResourceInclude Source="/Common/Themes/Resources.axaml"/>
        <MergeResourceInclude Source="/Common/Themes/WindowDrawnDecorationsControlTheme.axaml"/>
        <MergeResourceInclude Source="/Common/Converters/Converters.axaml" />
        <MergeResourceInclude Source="/Common/Progress/CircularProgressBar.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>